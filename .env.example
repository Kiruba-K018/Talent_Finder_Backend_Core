POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=talentfinder
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_SSL_MODE=prefer
POSTGRES_POOL_SIZE=3        # Maximum pool size (reduced for Cloud SQL)
POSTGRES_POOL_MIN_SIZE=1    # Minimum pool size

MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=mongo
MONGO_PASSWORD=mongo
MONGO_DB=talentfinder
MONGO_AUTHSOURCE=admin

OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_groq_api_key
CEREBRAS_API_KEY=your_cerebras_api_key

ACCESS_SECRET=your_strong_random_access_secret_key_here_min_32_chars
REFRESH_SECRET=your_strong_random_refresh_secret_key_here_min_32_chars
ALGORITHM=HS256
ACCESS_EXPIRE_MIN=15
REFRESH_EXPIRE_MIN=10080

CORS_ORIGINS=http://localhost:3001,http://localhost:3000
